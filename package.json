{
	"name": "pi-agent-system",
	"version": "0.1.2",
	"description": "Agent profile extension for the pi coding agent. Reads SANEPI_AGENT_TYPE / PI_AGENT_TYPE, loads markdown agent profiles, filters tools, and appends per-agent prompt fragments.",
	"type": "module",
	"license": "MIT",
	"homepage": "https://github.com/code-yeongyu/pi-agent-system",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/code-yeongyu/pi-agent-system.git"
	},
	"bugs": {
		"url": "https://github.com/code-yeongyu/pi-agent-system/issues"
	},
	"keywords": [
		"pi",
		"pi-mono",
		"pi-coding-agent",
		"pi-extension",
		"coding-agent",
		"agent-system",
		"subagents",
		"tool-filtering",
		"typescript"
	],
	"pi": {
		"extensions": [
			"./src/index.ts"
		]
	},
	"files": [
		"src",
		"LICENSE",
		"NOTICE",
		"README.md",
		"CHANGELOG.md"
	],
	"scripts": {
		"test": "vitest --run",
		"test:watch": "vitest",
		"typecheck": "tsgo --noEmit",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"check": "tsgo --noEmit && biome check ."
	},
	"peerDependencies": {
		"@mariozechner/pi-coding-agent": "*",
		"typebox": "*"
	},
	"dependencies": {
		"yaml": "^2.8.2"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.15",
		"@types/node": "^25.6.2",
		"@typescript/native-preview": "^7.0.0-dev.20260120.1",
		"typescript": "^6.0.3",
		"vitest": "^4.1.5"
	},
	"engines": {
		"node": ">=20.0.0"
	}
}
